# BizIntel Environment Variables
# Copy this file to .env and fill in your actual values

# ── LLM Provider ─────────────────────────────────────────────────────
# Set LLM_PROVIDER in src/bizintel/config/settings.py to "openai" or "groq"
# Then fill in the corresponding API key below.

# OpenAI API Key (required if LLM_PROVIDER = "openai")
OPENAI_API_KEY=sk-your-key-here

# Groq API Key — FREE tier (required if LLM_PROVIDER = "groq")
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here

# Tavily API Key (optional) — required only for web-search fallback
# If missing, BizIntel still works and web fallback is disabled.
# Get yours at: https://app.tavily.com/home
TAVILY_API_KEY=tvly_your-key-here
